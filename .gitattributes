# Normaliza fim de linha: LF no repositorio, nativo no disco de cada um.
* text=auto

*.java   text diff=java
*.html   text diff=html
*.css    text diff=css
*.xml    text diff=xml
*.properties text
*.md     text diff=markdown
*.json   text

*.jar    binary
*.png    binary
*.jpg    binary
*.ico    binary
*.mv.db  binary
